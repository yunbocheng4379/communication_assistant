# 职能沟通翻译助手

# LLM API配置
# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 硅基流动（国内可访问，推荐）
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# 阿里云通义千问
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 火山云豆包（推荐，国内可访问）
# API Key 在火山云控制台 -> 方舟平台获取
DOUBAO_API_KEY=your_doubao_api_key_here
# 豆包模型名称，默认使用doubao-pro
DOUBAO_MODEL=doubao-pro
# 豆包API地址（根据你的region选择）
# 华北: https://ark.cn-beijing.volces.com/api/v3
# 华东: https://ark.cn-shanghai.volces.com/api/v3
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# LLM提供商选择（不设置则自动检测）
# 可选值：openai, claude, siliconflow, qwen, doubao
LLM_PROVIDER=doubao

# 服务端口
PORT=8000
